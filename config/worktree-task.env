WEZDECK_REPO=.

WT_POLICY_WORKTREE_DIR=.worktrees/{repo}
WT_POLICY_METADATA_DIR=.worktrees/{repo}/.task-meta
WT_POLICY_BRANCH_PREFIX=task/
WT_POLICY_BRANCH_PREFIX_DEV=dev/
WT_POLICY_BRANCH_PREFIX_TASK=task/
WT_POLICY_BRANCH_PREFIX_HOTFIX=hotfix/
WT_POLICY_BASE_REF_STRATEGY=origin-default-branch
WT_POLICY_RECLAIM_DIRTY=refuse
WT_POLICY_RECLAIM_DELETE_BRANCH=merged-into-primary-head

WT_PROVIDER_MODE=auto
WT_PROVIDER=tmux-agent
WT_PROVIDER_WORKSPACE=task
WT_PROVIDER_DEFAULT_VARIANT=auto
WT_PROVIDER_ATTACH_DEFAULT=1
WT_PROVIDER_TMUX_CONFIG_FILE=tmux.conf
WT_PROVIDER_AGENT_COMMAND=
WT_PROVIDER_AGENT_COMMAND_LIGHT=
WT_PROVIDER_AGENT_COMMAND_DARK=
# Bare profiles — fresh agent on every pane open, no auto-resume.
# Kept for direct CLI invocation (`MANAGED_AGENT_PROFILE=claude
# worktree-task launch …`) and as the `exec claude` / `exec codex`
# fallback target inside the resume wrappers below when a cwd has no
# prior conversation. None of the wezterm/tmux entry points select these
# on their own anymore — they all force the resume variant.
WT_PROVIDER_AGENT_PROFILE_CLAUDE_COMMAND=claude
WT_PROVIDER_AGENT_PROFILE_CLAUDE_COMMAND_LIGHT=
WT_PROVIDER_AGENT_PROFILE_CLAUDE_COMMAND_DARK=
WT_PROVIDER_AGENT_PROFILE_CODEX_COMMAND=codex
WT_PROVIDER_AGENT_PROFILE_CODEX_COMMAND_LIGHT=codex
WT_PROVIDER_AGENT_PROFILE_CODEX_COMMAND_DARK=codex

# Resume profiles — auto-continue the cwd's most recent conversation.
# This is the default for every wezterm/tmux entry point: workspace
# first-open of `work` / `config` (managed_cli.default_resume_profile
# in wezterm-x/lua/constants.lua), `Ctrl+k g d/t/h` lifecycle hotkeys
# (dev/task/hotfix), the `Alt+g` / `Alt+Shift+G` picker when it creates
# a window on demand, and the legacy bare-name path of
# `open-task-window`. Resume-or-fresh fallback (`claude --continue`
# exits 1 with "No conversation found to continue" on a brand-new cwd;
# the `||` inside the launcher catches that and execs the bare CLI) is
# encapsulated in scripts/runtime/agent-launcher.sh, which also sources
# the managed-runtime env files via runtime_env_load_managed:
# wezterm-x/local/shared.env first, then ~/.config/shell-env.d/*.env
# (later wins). That is how secrets like CNB_TOKEN reach paths forked
# via tmux's plain `sh -c` (Alt+g window, refresh-current-window, tab-
# overflow cold-spawn, Happy toggle) without traversing any zsh rc
# file. The ${WEZTERM_REPO} placeholder is expanded in lockstep by:
# scripts/runtime/worktree/lib/resume-command.sh (Alt+g / refresh /
# cold-spawn via resolve_managed_primary_command), and
# wezterm-x/lua/config/managed_cli.lua::parse_managed_cli_env (WezTerm
# first-open).
WT_PROVIDER_AGENT_PROFILE_CLAUDE_RESUME_COMMAND=${WEZTERM_REPO}/scripts/runtime/agent-launcher.sh claude
WT_PROVIDER_AGENT_PROFILE_CLAUDE_RESUME_COMMAND_LIGHT=
WT_PROVIDER_AGENT_PROFILE_CLAUDE_RESUME_COMMAND_DARK=
WT_PROVIDER_AGENT_PROFILE_CODEX_RESUME_COMMAND=${WEZTERM_REPO}/scripts/runtime/agent-launcher.sh codex
WT_PROVIDER_AGENT_PROFILE_CODEX_RESUME_COMMAND_LIGHT=${WEZTERM_REPO}/scripts/runtime/agent-launcher.sh codex
WT_PROVIDER_AGENT_PROFILE_CODEX_RESUME_COMMAND_DARK=${WEZTERM_REPO}/scripts/runtime/agent-launcher.sh codex
