.sync-target
wezterm-x/local/
wezterm-x/tmux/chord-bindings.generated.conf
wezterm-x/tmux/appearance.generated.conf
native/picker/bin/
.claude/scheduled_tasks.lock
.claude/settings.local.json

# OpenClaw machine-local (never commit filled secrets or host paths)
openclaw/local/
# Runtime inbound media from Feishu / channel (Gateway workspace)
openclaw/workspace/media/
# OpenClaw agent daily/runtime memory (PII, host paths, task ledger)
openclaw/workspace/memory/
# ACP / agent runtime under linked workspace (sessions, smoke leftovers)
openclaw/workspace/state/
openclaw/workspace/claude/
openclaw/workspace/codex/
# Scratch / handoff files staged by agents (not source of truth)
openclaw/workspace/tmp/
openclaw/workspace/smoke-ok.txt
openclaw/workspace/**/smoke-ok.txt
openclaw/workspace/**/marker.txt
