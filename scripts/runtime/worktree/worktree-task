#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME_LOG_LIB="$SCRIPT_DIR/../../../scripts/runtime/runtime-log-lib.sh"
RUNTIME_ENV_LIB="$SCRIPT_DIR/../../../scripts/runtime/runtime-env-lib.sh"
# shellcheck disable=SC1091
source "$RUNTIME_LOG_LIB"
export WEZTERM_RUNTIME_LOG_SOURCE="worktree-task"
# Pull in managed env (shared.env + ~/.config/shell-env.d/*.env) so
# pre-agent git operations have the same credentials the interactive
# shell does. The common trigger path is `tmux run-shell -b` from
# `open-task-window`, which forks via `sh -c` and inherits none of the
# zsh-injected secrets (CNB_TOKEN, etc.) — without this load, the very
# first `git fetch origin` against a private CNB remote 404s.
# shellcheck disable=SC1091
source "$RUNTIME_ENV_LIB"
runtime_env_load_managed
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/helpers.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/git.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/config.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/manifest.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/core.sh"

WT_SCRIPTS_DIR="$SCRIPT_DIR"

command="${1:-}"
shift || true

case "$command" in
  configure)
    wt_core_configure "$@"
    ;;
  launch)
    wt_core_launch "$@"
    ;;
  reclaim)
    wt_core_reclaim "$@"
    ;;
  -h|--help|help|'')
    wt_core_usage
    ;;
  *)
    wt_core_usage >&2
    exit 1
    ;;
esac
