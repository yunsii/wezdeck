#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
set +e
"$SCRIPT_DIR/create-prompt" --type dev "$@"
rc=$?
set -e
if [[ "$rc" -ne 0 ]]; then
  printf '\ncreate-prompt-dev failed (rc=%d). Press Esc to close, or wait 30 seconds.\n' "$rc" >&2
  sleep 30
  exit "$rc"
fi
