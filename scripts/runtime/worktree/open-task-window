#!/usr/bin/env bash
# open-task-window — quick-create a lifecycle worktree. The user's short
# <name> is kept as the subject title, while the local worktree slug carries
# lifecycle (`dev-<subject>`, `task-<subject>`, `hotfix-<subject>`) and the
# git branch uses the type-specific team prefix (`dev/<subject>`,
# `task/<subject>`, `hotfix/<subject>` by default). Collisions are bumped
# consistently to `<subject>-2`, `<subject>-3`, … across both names.
#
# `--type dev|task|hotfix` opts into the lifecycle-aware path. Opening an
# already-existing worktree belongs to `Alt+g` / `Alt+Shift+g`, not here.
# Every lifecycle — and the legacy bare path — uses the `<base>-resume`
# profile so the agent auto-continues the cwd's most recent conversation;
# when no prior conversation exists, the resume command falls back to a
# fresh agent on its own. `<base>` defaults to whatever
# MANAGED_AGENT_PROFILE selects (claude / codex / …).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WEZTERM_CONFIG_REPO_DEFAULT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
WORKTREE_TASK_CLI="$SCRIPT_DIR/worktree-task"
RUNTIME_LIB_DIR="$WEZTERM_CONFIG_REPO_DEFAULT/scripts/runtime"

# shellcheck disable=SC1091
source "$RUNTIME_LIB_DIR/runtime-log-lib.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/helpers.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/git.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/config.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/core.sh"

export WEZTERM_RUNTIME_LOG_SOURCE="worktree-task.open-window"

usage() {
  cat <<'EOF'
usage: open-task-window [--type dev|task|hotfix] <name>

Quick-create a task workspace for <name>. `worktree-task` treats <name> as
a subject title. In lifecycle mode the local worktree slug is
`<type>-<subject-slug>` while the branch is
`<type-branch-prefix><subject-slug>`. Existing worktrees or branches bump
both names to `<subject-slug>-2`, `<subject-slug>-3`, etc. Use `Alt+g` /
`Alt+Shift+g` to reopen an already-existing worktree instead.

  --type dev      long-lived parallel dev workstation
  --type task     short-lived focused task (PR-scoped)
  --type hotfix   urgent fix

All lifecycles (and the legacy bare-name path) launch with the
`<base>-resume` profile so the agent auto-continues the cwd's most
recent conversation; the resume command falls back to a fresh agent
when no prior conversation exists for that cwd.
EOF
}

die() {
  printf 'open-task-window: %s\n' "$1" >&2
  exit 1
}

type_kind=""
raw=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --type)
      [[ $# -ge 2 ]] || die "--type requires a value (dev, task, or hotfix)"
      type_kind="$2"
      shift 2
      ;;
    --type=*)
      type_kind="${1#--type=}"
      shift
      ;;
    --)
      shift
      [[ $# -eq 1 && -n "${1:-}" ]] || { usage >&2; exit 1; }
      raw="$1"
      shift
      ;;
    -*)
      die "unknown flag: $1"
      ;;
    *)
      [[ -z "$raw" ]] || die "expected exactly one positional <name>, got more"
      raw="$1"
      shift
      ;;
  esac
done

[[ -n "$raw" ]] || { usage >&2; exit 1; }

case "$type_kind" in
  ""|dev|task|hotfix) ;;
  *) die "invalid --type: $type_kind (expected dev, task, or hotfix)" ;;
esac

normalize_subject() {
  local value="${1:-}"
  case "$value" in
    task/|dev/|hotfix/) printf '\n' ;;
    task/*)             printf '%s\n' "${value#task/}" ;;
    dev/*)              printf '%s\n' "${value#dev/}" ;;
    hotfix/*)           printf '%s\n' "${value#hotfix/}" ;;
    "${type_kind}-"*)   printf '%s\n' "${value#"$type_kind"-}" ;;
    *)                  printf '%s\n' "$value" ;;
  esac
}

branch_prefix_for_type() {
  case "$type_kind" in
    dev)    printf '%s\n' "${WT_POLICY_BRANCH_PREFIX_DEV:-$WT_POLICY_BRANCH_PREFIX}" ;;
    task)   printf '%s\n' "${WT_POLICY_BRANCH_PREFIX_TASK:-$WT_POLICY_BRANCH_PREFIX}" ;;
    hotfix) printf '%s\n' "${WT_POLICY_BRANCH_PREFIX_HOTFIX:-$WT_POLICY_BRANCH_PREFIX}" ;;
    *)      printf '%s\n' "$WT_POLICY_BRANCH_PREFIX" ;;
  esac
}

resolve_names() {
  local subject_slug base_worktree_slug branch_prefix suffix

  title="$(normalize_subject "$raw")"
  [[ -n "$title" ]] || die "task name is empty after stripping lifecycle prefix"

  if [[ -z "$type_kind" ]]; then
    task_slug=""
    branch_name=""
    return 0
  fi

  wt_core_resolve_repo_context "$PWD"
  wt_config_load
  wt_core_resolve_policy_paths

  subject_slug="$(wt_slugify "$title" "$WT_POLICY_SLUG_FALLBACK")"
  base_worktree_slug="${type_kind}-${subject_slug}"
  branch_prefix="$(branch_prefix_for_type)"
  task_slug="$base_worktree_slug"
  branch_name="${branch_prefix}${subject_slug}"
  suffix=1

  while [[ -e "$WT_POLICY_WORKTREE_DIR_ABS/$task_slug" ]] || wt_git_branch_exists "$WT_MAIN_WORKTREE_ROOT" "$branch_name"; do
    suffix=$((suffix + 1))
    task_slug="${base_worktree_slug}-${suffix}"
    branch_name="${branch_prefix}${subject_slug}-${suffix}"
  done
}

title=""
task_slug=""
branch_name=""
resolve_names

# Profile selection. Resolve the "base" profile from the user's preference
# (MANAGED_AGENT_PROFILE in shared.env), strip any trailing `-resume` so we
# re-derive cleanly, then always pick the resume variant — every lifecycle
# (dev/task/hotfix) and the legacy bare path want cwd auto-resume; if there
# is no prior conversation for the cwd, the resume command falls back to a
# fresh agent on its own.
base_profile="${MANAGED_AGENT_PROFILE:-claude}"
base_profile="${base_profile%-resume}"
selected_profile="${base_profile}-resume"
quick_create_provider="${WT_QUICK_CREATE_PROVIDER:-tmux-agent}"
quick_create_provider_mode="${WT_QUICK_CREATE_PROVIDER_MODE:-auto}"

[[ -x "$WORKTREE_TASK_CLI" ]] || die "worktree-task CLI not found or not executable: $WORKTREE_TASK_CLI"

launch_env=(env)
if [[ -z "${WEZTERM_CONFIG_REPO:-}" ]]; then
  launch_env+=("WEZTERM_CONFIG_REPO=$WEZTERM_CONFIG_REPO_DEFAULT")
fi
if [[ -n "$selected_profile" ]]; then
  launch_env+=("MANAGED_AGENT_PROFILE=$selected_profile")
fi
# `env` with no extra args is a noop wrapper; the shape stays consistent
# whether we set anything or not.

runtime_log_info worktree "dispatching to worktree-task launch" \
  "raw=$raw" "type=${type_kind:-<none>}" "title=$title" "task_slug=${task_slug:-<auto>}" "branch=${branch_name:-<auto>}" "profile=${selected_profile:-<inherit>}"

# Immediate feedback so the user sees the chord registered before any
# slow git/fetch work starts. Each downstream stage will replace this
# message in the same status-line slot. No-op outside tmux.
if [[ -n "${TMUX:-}" ]]; then
  tmux_session="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
  if [[ -n "$tmux_session" ]]; then
    tmux set-option -q -t "$tmux_session" '@tmux_status_override_line_2' \
      "[worktree-task] preparing ${task_slug:-$title}…" 2>/dev/null || true
    tmux refresh-client -S 2>/dev/null || true
  fi
fi

launch_args=(
  launch
  --title "$title"
  --provider "$quick_create_provider"
  --provider-mode "$quick_create_provider_mode"
)
if [[ -n "${WT_QUICK_CREATE_BASE_REF:-}" ]]; then
  launch_args+=(--base-ref "$WT_QUICK_CREATE_BASE_REF")
fi
if [[ -n "$task_slug" ]]; then
  launch_args+=(--task-slug "$task_slug")
fi
if [[ -n "$branch_name" ]]; then
  launch_args+=(--branch "$branch_name")
fi

exec "${launch_env[@]}" "$WORKTREE_TASK_CLI" "${launch_args[@]}"
