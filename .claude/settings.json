{
  "permissions": {
    "allow": [
      "Bash(deepwiki-mcp-cli ask_question *)",
      "Bash(pnpm lint)",
      "Bash(pnpm typecheck)",
      "Bash(npm view *)",
      "Bash(npm list *)",
      "Bash(npm info *)",
      "Bash(tmux list-keys *)",
      "Bash(tmux list-sessions *)",
      "Bash(tmux list-windows *)",
      "Bash(tmux list-panes *)",
      "Bash(tmux show-options *)",
      "Bash(tmux show-environment *)",
      "Bash(tmux display-message *)",
      "Bash(tmux ls *)",
      "Bash(tmux show *)",
      "Bash(tmux display *)",
      "Bash(command -v *)",
      "Bash(gh search *)",
      "Bash(tasklist.exe)",
      "Bash(reg.exe query *)",
      "Bash(dotnet --version)",
      "Bash(env)",
      "Bash(apt list *)",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__take_screenshot",
      "WebSearch",
      "WebFetch(domain:wezterm.org)",
      "WebFetch(domain:github.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/claude-hooks/block-direct-windows-shell.sh"
          }
        ]
      }
    ]
  }
}
