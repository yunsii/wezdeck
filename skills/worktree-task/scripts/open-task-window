#!/usr/bin/env bash
# open-task-window — quick-create a task workspace: hand a short <name> to
# `worktree-task launch` as the task title so slug and branch follow the
# same `wt_slugify` / `task/<slug>` convention the skill uses on its own,
# then start the configured agent in the new tmux window without feeding it
# any prompt. Collisions are bumped to `<slug>-2`, `<slug>-3`, … by the
# skill — opening an already-existing task worktree belongs to `Alt+g` /
# `Alt+Shift+g`, not here. Full lifecycle (prompt, reclaim, custom
# provider) still belongs to `worktree-task launch`/`reclaim`.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WEZTERM_CONFIG_REPO_DEFAULT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
WORKTREE_TASK_CLI="$SCRIPT_DIR/worktree-task"
RUNTIME_LIB_DIR="$WEZTERM_CONFIG_REPO_DEFAULT/scripts/runtime"

# shellcheck disable=SC1091
source "$RUNTIME_LIB_DIR/runtime-log-lib.sh"

export WEZTERM_RUNTIME_LOG_SOURCE="worktree-task.open-window"

usage() {
  cat <<'EOF'
usage: open-task-window <name>

Quick-create a task workspace for <name>. The skill treats <name> as a task
title, slugifies it (lowercase + `-` separators), and creates branch
`task/<slug>` with a linked worktree under `.worktrees/<repo>/<slug>/`. A
leading `task/` in <name> is stripped so `fix-auth` and `task/fix-auth`
produce the same result. Existing worktrees with the same slug cause the
skill to bump to `<slug>-2`, `<slug>-3`, etc. — use `Alt+g` /
`Alt+Shift+g` to reopen an already-existing task worktree instead.
EOF
}

die() {
  printf 'open-task-window: %s\n' "$1" >&2
  exit 1
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

[[ $# -eq 1 && -n "${1:-}" ]] || { usage >&2; exit 1; }
raw="$1"

# Strip one optional `task/` prefix so typing the skill's canonical branch
# form produces the same output as the short name. Everything past the
# prefix goes to the skill as a title, which handles slugification itself.
case "$raw" in
  task/)  die "task name is empty after stripping 'task/' prefix" ;;
  task/*) title="${raw#task/}" ;;
  *)      title="$raw" ;;
esac

[[ -x "$WORKTREE_TASK_CLI" ]] || die "worktree-task CLI not found or not executable: $WORKTREE_TASK_CLI"

launch_env=()
if [[ -z "${WEZTERM_CONFIG_REPO:-}" ]]; then
  launch_env+=(env "WEZTERM_CONFIG_REPO=$WEZTERM_CONFIG_REPO_DEFAULT")
fi

runtime_log_info worktree "dispatching to worktree-task launch" "raw=$raw" "title=$title"

exec "${launch_env[@]}" "$WORKTREE_TASK_CLI" launch \
  --title "$title" \
  --provider tmux-agent \
  --provider-mode auto \
  --no-prompt
