# Shared scalar config for both Lua and shell runtime code.
# Copy this file to wezterm-x/local/shared.env and fill in private values there.

WAKATIME_API_KEY='your-wakatime-api-key'

# Optional: mirror your preferred managed agent profile here for quick reference.
# The actual launcher switch shared by WezTerm and worktree-task lives in
# ~/.config/worktree-task/config.env via WT_PROVIDER_AGENT_PROFILE.
# MANAGED_AGENT_PROFILE='codex'
