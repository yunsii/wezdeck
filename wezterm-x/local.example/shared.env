# Shared scalar config for both Lua and shell runtime code.
# Copy this file to wezterm-x/local/shared.env and fill in private values there.
#
# Scope: this file is for repo-machine config consumed by *both* Lua and
# shell — values that must be synced to the Windows runtime alongside the
# rest of wezterm-x/. For user-level secrets (CNB tokens, third-party API
# keys, etc.) prefer `~/.config/shell-env.d/<name>.env` instead; that
# directory is auto-discovered by `~/.zshrc` and the runtime loader
# together, so adding a secret needs no rc-file edits and no loader
# edits. Full convention: docs/setup.md#env-loading-model.

WAKATIME_API_KEY='your-wakatime-api-key'

# Machine-local default agent profile shared by WezTerm and worktree-task.
# Supported tracked profiles currently include 'claude' and 'codex'.
MANAGED_AGENT_PROFILE='claude'

# VS Code profile name used by Alt+v (recommended: 'ai-dev'). Leave empty or
# unset to fall back to VS Code's default profile. The template for ai-dev
# lives at wezterm-x/local.example/vscode/ai-dev.code-profile.
WEZTERM_VSCODE_PROFILE='ai-dev'
