# Wezterm-config user-level env vars. Mode 600.
#
# Install (once):
#   mkdir -p ~/.config/shell-env.d
#   cp wezterm-x/local.example/shell-env.d/wezterm-env.env ~/.config/shell-env.d/
#   chmod 600 ~/.config/shell-env.d/wezterm-env.env
#
# Loaded by both ~/.zshrc and scripts/runtime/runtime-env-lib.sh::
# runtime_env_load_managed, so whatever lives here is visible in
# interactive shells AND in agent processes spawned via
# scripts/runtime/agent-launcher.sh.
#
# Scope: pure env vars. Aliases and zsh functions live in the sibling
# wezterm-fn.env (functions cannot survive a subprocess boundary, so
# the runtime loader treats that file as a no-op).
#
# Lex-order pairing with wezterm-fn.env: `-env.` < `-fn.`, so this
# file loads first and `wezterm-fn.env` can reference values set
# below at definition time, not just at call time.

# Repo root anchor. Edit if you cloned the repo somewhere other than
# ~/github/wezterm-config.
export WEZTERM_REPO="$HOME/github/wezterm-config"

# User-facing CLI commands live under scripts/runtime/cli/ (no .sh
# suffix). Prepending the dir to PATH lets you add a new command with
# a single file drop — no rc-file edits, no PATH edits, no symlinks.
export PATH="$WEZTERM_REPO/scripts/runtime/cli:$PATH"
