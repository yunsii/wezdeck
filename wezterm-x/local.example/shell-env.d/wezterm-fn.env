# Wezterm-config user-level shell functions / aliases. Mode 600.
#
# Install (once):
#   mkdir -p ~/.config/shell-env.d
#   cp wezterm-x/local.example/shell-env.d/wezterm-fn.env ~/.config/shell-env.d/
#   chmod 600 ~/.config/shell-env.d/wezterm-fn.env
#
# Scope: things that must run in the parent shell — `cd`-ing
# helpers, completion hooks, prompt tweaks, aliases. Plain
# subprocess-runnable tooling belongs in scripts/runtime/cli/ instead
# (see sibling wezterm-env.env).
#
# Loaded by ~/.zshrc (functions persist for the interactive session)
# and by the runtime env loader (functions define and immediately
# vanish with the subprocess — harmless, just useless there).
#
# Convention: prefix function and alias names with `wez-` or
# `wezterm-` so they cannot shadow a real binary that a subprocess
# might rely on.

# Example: uncomment to jump to the repo from anywhere.
#
# wez() {
#   cd "${WEZTERM_REPO:?wezterm-env.env not loaded}/${1:-}"
# }
