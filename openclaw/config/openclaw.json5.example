// Desensitized sketch for ~/.openclaw/openclaw.json (or .json5).
// Merge by hand after install. Field names follow upstream docs; rename if your
// OpenClaw version differs — this is a checklist, not a live dump.
//
// NEVER put real App Secret, API keys, or gateway tokens in this tracked file.
// Prefer ~/.config/shell-env.d/*.env (mode 600) or local secret stores.

{
  // tools: {
  //   profile: "coding", // allows bundle-mcp (configured mcp.servers)
  //   elevated: { enabled: false },
  //   // Prefer mode alone — do not combine with tools.exec.security / ask
  //   exec: {
  //     // Personal OpenClaw (Dex): full + ask off + strictInlineEval false.
  //     // Semantic risk → claw-run / skills/exec-risk (not platform /approve).
  //     mode: "full",
  //     host: "gateway",
  //     strictInlineEval: false,
  //     // safeBinTrustedDirs: ["/bin", "/usr/bin"],
  //   },
  // },

  // Core: attach to WezDeck Windows debug Chrome (CDP). Local only — do not
  // commit live openclaw.json. Port must match chrome_debug_browser.remote_debugging_port.
  // mcp: {
  //   servers: {
  //     "chrome-devtools": {
  //       command: "npx",
  //       args: [
  //         "-y",
  //         "chrome-devtools-mcp@latest",
  //         "--browser-url=http://127.0.0.1:9222",
  //       ],
  //       connectTimeout: 60,
  //       timeout: 90,
  //     },
  //   },
  // },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      // skipBootstrap: true  // when workspace is symlinked from this repo
      // model: { primary: "xai/grok-4.3" },
      // or custom proxy provider (see models.providers below):
      // model: { primary: "grok-proxy/grok-4.5" },
      // models: allowlist only intended providers — do NOT add claude-cli/*
      //   or model.fallbacks: ["claude-cli/…"] (CLI backend disabled by policy).
      // cliBackends: { }  // leave unset — mode D disabled
    },
  },

  // ACP harness (mode E) — local only; personal machines may use approve-all
  // acp: {
  //   enabled: true,
  //   backend: "acpx",
  //   defaultAgent: "claude",
  //   allowedAgents: ["claude", "codex"],
  //   maxConcurrentSessions: 4,
  //   runtime: { ttlMinutes: 120 },
  // },
  // plugins.allow must include "acpx"; plugins.entries.acpx.enabled: true
  // plugins.entries.acpx.config.permissionMode: "approve-all" // personal break-glass

  // Optional: OpenAI-compatible proxy (same idea as a local Grok CLI baseUrl).
  // models: {
  //   mode: "merge",
  //   providers: {
  //     "grok-proxy": {
  //       baseUrl: "https://YOUR-PROXY.example/v1",
  //       apiKey: "YOUR_KEY_OR_ENV_REF",
  //       api: "openai-responses",
  //       models: [
  //         {
  //           id: "grok-4.5",
  //           name: "Grok",
  //           api: "openai-responses",
  //           reasoning: true,
  //           input: ["text"],
  //           cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
  //           contextWindow: 200000,
  //           maxTokens: 32000,
  //         },
  //       ],
  //     },
  //   },
  // },

  // channels: {
  //   feishu: {
  //     enabled: true,
  //     domain: "feishu", // or "lark"
  //     dmPolicy: "allowlist", // or "pairing"; never "open" for personal MVP
  //     allowFrom: ["ou_YOUR_OPEN_ID"],
  //     groupPolicy: "allowlist",
  //     requireMention: true,
  //     tools: {
  //       doc: false,
  //       wiki: false,
  //       drive: false,
  //       perm: false,
  //       bitable: false,
  //       chat: true,
  //       scopes: true,
  //     },
  //     defaultAccount: "main",
  //     accounts: {
  //       main: {
  //         appId: "cli_xxx",
  //         appSecret: "FROM_LOCAL_SECRET_ONLY",
  //         name: "Dex", // Feishu-facing display label (Dex)
  //       },
  //     },
  //   },
  // },

  // plugins: {
  //   allow: ["feishu"],
  //   entries: {
  //     feishu: { enabled: true },
  //   },
  // },

  // gateway: {
  //   mode: "local",
  //   bind: "loopback",
  //   port: 18789,
  //   auth: { mode: "token" }, // token value is local-only
  // },
}
