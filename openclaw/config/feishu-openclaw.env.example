# Copy to ~/.config/shell-env.d/feishu-openclaw.env with mode 600.
#   install -m 600 openclaw/config/feishu-openclaw.env.example \
#     ~/.config/shell-env.d/feishu-openclaw.env
#
# Fill real values ONLY in the local copy. Never commit filled files.
# Exact variable names: align with OpenClaw Feishu channel docs for your version
# (https://docs.openclaw.ai/channels/feishu).

# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=

# Optional alternate names if your OpenClaw build expects them:
# OPENCLAW_FEISHU_APP_ID=
# OPENCLAW_FEISHU_APP_SECRET=

# Model keys belong in separate env files (e.g. grok-proxy.env), not mixed here
# unless you intentionally share one file locally.
