# Copy to ~/.config/shell-env.d/openclaw-tasks.env (mode 600).
#   install -m 600 openclaw/config/openclaw-tasks.env.example \
#     ~/.config/shell-env.d/openclaw-tasks.env
#
# Fill from a created Feishu Base (see openclaw/README.md § Task ledger).
# Never commit the filled file.

# OPENCLAW_TASKS_BASE_TOKEN=
# OPENCLAW_TASKS_TABLE_ID=
# OPENCLAW_TASKS_LARK_AS=bot
# OPENCLAW_TASKS_BASE_URL=https://xxx.feishu.cn/base/…

# Optional: colon-separated absolute roots for this machine only.
# Default when unset (portable): coco-forge + wezdeck (wezterm-config) under $HOME.
# Example (do not commit a filled file):
# OPENCLAW_TASKS_ALLOWED_ROOTS=$HOME/work/coco-forge:$HOME/work/.worktrees/coco-forge:$HOME/github/wezterm-config:$HOME/github/.worktrees/wezterm-config:$HOME/work/wezterm-config:$HOME/work/.worktrees/wezterm-config
