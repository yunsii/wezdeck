# Copy to ~/.config/shell-env.d/openclaw-tasks.env (mode 600).
#   install -m 600 openclaw/config/openclaw-tasks.env.example \
#     ~/.config/shell-env.d/openclaw-tasks.env
#
# Secrets only for Feishu Base ledger. Never commit the filled file.
#
# Write-path allowlist is NOT here — use config file:
#   ~/.openclaw/tasks-allowlist.json
#   (from openclaw/config/tasks-allowlist.json.example)

# OPENCLAW_TASKS_BASE_TOKEN=
# OPENCLAW_TASKS_TABLE_ID=
# OPENCLAW_TASKS_LARK_AS=bot
# OPENCLAW_TASKS_BASE_URL=https://xxx.feishu.cn/base/…

# Optional: which agent id the ledger path guard uses (default main).
# OPENCLAW_TASKS_AGENT=main
